# 复制为 .env 后运行 npm run setup

# ── 数据库 ─────────────────────────────────────────────
# 开发/CI：本地 SQLite 文件。
# 生产：PostgreSQL，例如 postgresql://user:pass@host:5432/tide?schema=public
# （切换到 PostgreSQL 时需同步改 prisma/schema.prisma 的 datasource provider）
DATABASE_URL="file:./dev.db"

# ── 会话 ───────────────────────────────────────────────
# 必填：用于会话签名/加密的随机密钥（生产环境必须设置，勿留空）。
# 生成示例：openssl rand -hex 32
SESSION_SECRET=""

# ── 支付渠道密钥 ───────────────────────────────────────
# 各渠道 webhook 签名密钥（HMAC-SHA256）。缺失时回退到 PAY_MOCK_SECRET。
# 生产必须为每个启用的渠道配置真实密钥。
PAY_MOCK_SECRET="dev-mock-secret"
PAY_WEB_WECHAT_SECRET=""
PAY_WEB_ALIPAY_SECRET=""
PAY_STRIPE_SECRET=""

# ── 站点 ───────────────────────────────────────────────
# 对外可访问的站点根 URL（用于回调、分享链接、邮件等）。
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── AI（DeepSeek，OpenAI 兼容）─────────────────────────
# 全局 LLM 能力：课程 AI 辅助、笔记 AI 总结、共创回复起草、语义搜索。
# 申请：https://platform.deepseek.com/ ；缺失时 AI 功能优雅缺席，不影响其余功能。
DEEPSEEK_API_KEY=""

# ── 存储（视频/封面上传）───────────────────────────────
# mock：本地占位（开发/演示）；oss/s3：真实对象存储（需另配 AK/SK/bucket）。
STORAGE_MODE="mock"

# ── 视频课件生成（v3.1）─────────────────────────────────
# mock（默认）：把块课件转成带旁白脚本的视频占位，不调任何生视频模型；
# real：接入真实文生视频/数字人讲课 provider（需实现 src/lib/video-gen.ts 的 VideoProvider 并配 VIDEO_PROVIDER）。
# 真实 provider 未接入时即便设 real 也会优雅回落 mock。
VIDEO_MODE="mock"
# 真实模式下选择 provider 实现（如 wan/heygen/sadtalker，见 video-gen.ts 的 TODO）。
VIDEO_PROVIDER=""

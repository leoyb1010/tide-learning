# 复制为 .env 后运行 npm run setup

# ── 数据库 ─────────────────────────────────────────────
# 开发/CI：本地 SQLite 文件。
# 生产：务必用绝对路径，例如 file:/var/lib/tide/prod.db。
#       相对路径（file:./dev.db）会随进程工作目录漂移、也易在部署脚本里被误删。
# 生产（PostgreSQL）：postgresql://user:pass@host:5432/tide?schema=public
# （切换到 PostgreSQL 时需同步改 prisma/schema.prisma 的 datasource provider）
DATABASE_URL="file:./dev.db"

# ── 会话 ───────────────────────────────────────────────
# 说明：SESSION_SECRET 当前未启用（session 走数据库不透明 token，不做 JWT/签名）。
#       如未来改为签名/加密会话再启用；现阶段留此说明，无需配置。

# ── 支付渠道密钥 ───────────────────────────────────────
# 各渠道 webhook 签名密钥（HMAC-SHA256）。缺失即抛错拒绝该渠道回调——
# 绝不回退到共享/默认密钥（见 payment-provider.ts secretFor 的说明）。
# 生产必须为每个启用的渠道配置真实密钥。
# ⚠️ 生产严禁使用下方示例值 dev-mock-secret：启动校验（src/instrumentation.ts）会拒绝启动。
PAY_MOCK_SECRET="dev-mock-secret"
PAY_WEB_WECHAT_SECRET=""
PAY_WEB_ALIPAY_SECRET=""
# Stripe 真实渠道（一次性 Checkout）。分别来自 Stripe API keys 与 Webhooks 端点。
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Web 收银台渠道：mock 仅非生产可用；生产当前只支持 stripe。
NEXT_PUBLIC_PAY_CHANNEL="mock"

# ── 反向代理 ───────────────────────────────────────────
# 可信反代层数（用于限流取真实客户端 IP，见 rate-limit.ts）。
# nginx 单层反代 = 1（默认）；前面再套 CDN 每层 +1。
TRUSTED_PROXY_HOPS="1"
# 生产默认把限流桶持久化到 .data/rate-limits；可改到与 SQLite 同一持久卷。
RATE_LIMIT_STORE="file"
RATE_LIMIT_DIR=""

# ── 站点 ───────────────────────────────────────────────
# 对外可访问的站点根 URL（用于 OG/分享卡、robots、sitemap、回调、邮件等）。
# ⚠️ 生产必须改为真实公开域名，且【构建期与运行期都要设置】——该值在 build 时被烤进 OG 图链接；
#    若留 localhost，分享到微信/X 的预览图会指向本地失效（instrumentation 生产启动会告警）。
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 学员码/二维码域名前缀（profile 设置页与 StudentCard 生成二维码时取此值拼绝对链接）。
# 需与对外访问域一致，否则扫码落到错误站点；本地示例：
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AI（Youdao NewAPI，OpenAI 兼容）──────────────────────
# 全局 LLM 能力：课程 AI 辅助、笔记 AI 总结、共创回复起草、语义搜索。
# 真实 sk-* 密钥只放在本地 .env / 部署密钥管理中，禁止提交到 Git。
NEWAPI_API_KEY=""
NEWAPI_BASE_URL="https://newapi.inner.youdao.com/v1"
NEWAPI_DEFAULT_MODEL="gpt-5.5"
# 兼容旧 DeepSeek 配置：如仍需回退旧模型，可在 src/lib/ai/models.ts 重新启用对应条目。
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=""

# ── 存储（视频/封面上传）───────────────────────────────
# mock：本地占位（仅开发/演示）；local：私有目录落盘并由鉴权接口流式输出。
STORAGE_MODE="mock"
MEDIA_DIR=""
# 生产必填且至少 32 字符，用于 /api/stream 短时 URL HMAC 签名。
STREAM_SIGNING_SECRET=""

# ── 视频课件生成（v3.1）─────────────────────────────────
# mock（默认）：把块课件转成带旁白脚本的视频占位，不调任何生视频模型；
# real：接入真实文生视频/数字人讲课 provider（需实现 src/lib/video-gen.ts 的 VideoProvider 并配 VIDEO_PROVIDER）。
# 真实 provider 未接入时即便设 real 也会优雅回落 mock。
VIDEO_MODE="mock"
# 真实模式下选择 provider 实现（如 wan/heygen/sadtalker，见 video-gen.ts 的 TODO）。
VIDEO_PROVIDER=""

# ── 苹果内购（IAP）真实校验 ────────────────────────────
# App Store Server API 的 JWS 交易离线校验（见 src/lib/apple-iap.ts）。
# 两项齐全 = 启用真实校验：对 jwsRepresentation 校验证书链（根到 Apple Root CA - G3）、
# 签名、bundleId/environment/productId/transactionId、过期/撤销。
# 缺失时：非生产走 mock 直发（本机/测试用）；生产一律拒绝（不放行任何发放）。
# App 的 bundle identifier，须与交易签名内的 bundleId 完全一致（如 com.youdao.tide）。
APPLE_BUNDLE_ID=""
# 部署对应的苹果环境，必须与交易签名内 environment 一致：Sandbox（测试）或 Production（正式）。
APPLE_IAP_ENVIRONMENT="Sandbox"

# ── 生产开关（默认关/留空；仅在明确需要时开启）─────────
# 苹果 IAP 校验放行：生产默认禁用（防无限白刷积分/年卡）。
# ⚠️ 置 1 前必须先配好上面的 APPLE_BUNDLE_ID + APPLE_IAP_ENVIRONMENT，否则生产会因未配置而拒绝全部发放。
APPLE_IAP_ENABLED=""
# mock 收银台仅限 development/test；生产设置为 1 会拒绝启动。
MOCK_PAY_ENABLED=""
# 种子管理员初始密码：留空则用内置默认（admin123）；生产建议设强密码后再跑 seed。
SEED_ADMIN_PASSWORD=""

// 潮汐学习 数据模型 — 对应产品计划书 v0.3 §9
// 订单 / 订阅 / 权益分表（§7.3 后端原则），客户端不判断权益。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- §9.1 用户与账户 ----------
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?   @unique
  username     String?   @unique // 短用户名登录（如体验账号 dingyue / admin）；新注册留空，仅 seed 账号使用
  nickname     String
  avatarUrl    String?
  authProvider String    @default("password") // password / wechat
  passwordHash String?
  role         String    @default("user") // user / admin / content_manager / demand_moderator / support / finance / reviewer
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  profile        UserProfile?
  sessions       Session[]
  progress       LearningProgress[]
  notes          Note[]
  demands        Demand[]
  votes          DemandVote[]
  orders         Order[]
  subscriptions  Subscription[]
  entitlements   Entitlement[]
  events         AnalyticsEvent[]
  comments       Comment[]
  demandFollows  DemandFollow[]
  streak         Streak?
  streakDays     StreakDay[]
  achievements   UserAchievement[]
  passwordResets PasswordReset[]
  importedSources ImportedSource[]
  generationJobs GenerationJob[]
  chatThreads    ChatThread[]
  reviewCards    ReviewCard[]
  notebooks      Notebook[]
  posts          Post[]
  postLikes      PostLike[]
  focusSessions  FocusSession[]
  creditAccount  CreditAccount?
  creditLedger   CreditLedger[]
  llmUsage       LlmUsage[]
  postComments   PostComment[]
  exams          Exam[]
  examAttempts   ExamAttempt[]
  examMistakes   ExamMistake[]
  notifications  Notification[]
  devices        Device[]
  courseReviews  CourseReview[]
  coursePurchases CoursePurchase[]
  inviteCode     InviteCode?       @relation("InviteCodeOwner")
  referralsMade  Referral[]        @relation("ReferralInviter")
  referralReceived Referral?       @relation("ReferralInvitee")
  redemptions    RedemptionRecord[]
  createdRedemptionCodes RedemptionCode[] @relation("RedemptionCodeCreator")

  @@index([role])
}

model UserProfile {
  userId                  String  @id
  user                    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthYear               Int?
  ageBand                 String? // 18-24 / 22-40 / 35-45 / 45-65
  learningGoal            String?
  preferredMode           String  @default("standard") // standard / elder
  fontScale               Float   @default(1.0)
  notificationPreferences String  @default("{}")
  motto                   String? // v2.3：学生证个性格言
  bio                     String? // v3.0：学习心得，个人主页展示
  showProfile             String  @default("{}") // v3.0：个人主页展示开关 JSON {stats,badges,posts}
  nicknameChangedAt       DateTime? // v3.0：改名冷却（30 天）
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

// ---------- 密码重置（A1-10：找回密码）----------
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256(token)，明文 token 仅回传一次
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------- §9.2 课程 ----------
model Course {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  subtitle         String?
  description      String?
  category         String // 赛道/内容板块 key（见 src/lib/tracks.ts）
  level            String // L1 / L2 / L3
  status           String    @default("draft") // draft / beta / published / archived
  coverColor       String    @default("tide") // 用渐变色替代封面图，避免二进制资源
  ownerId          String?
  // —— AI 自习室：课程来源与归属 ——
  origin           String    @default("official") // official / ai_generated / user_imported
  authorUserId     String?   // AI生成课/导入课的归属用户；官方课为 null
  visibility       String    @default("public")   // public / private / unlisted
  // —— 课程集市：分享到社区的审核状态 ——
  sharedStatus     String    @default("private")  // private / pending / shared / rejected
  // —— 课程集市：定价（S4 交易闭环 §问题⑪）——
  // priceCredits: 上架集市时作者设定的售价（积分）。null 或 0 = 免费 fork（保持原免费拿走语义）；
  //   >0 = 付费课，买家扣积分、作者入账（走 CreditLedger course_purchase / course_sale_income）。
  //   用「null=免费」而非独立 isPaid 布尔：单字段即可表达「免费 / N 积分」，少一个可能与价格打架的冗余源。
  //   派生的 isPaid（priceCredits>0）在 view 层算，不落库，避免两个真值源不一致。
  priceCredits     Int?      // 集市售价（积分）；null/0=免费，>0=付费
  salesCount       Int       @default(0) // 累计成交数（付费被购买次数；免费拿走不计入，销量口径 = 真实成交）
  genStatus        String?   // 生成态：generating / ready / failed（仅 AI/import 课）
  template         String?   // v3.2 课件模板 key（见 src/lib/ai/templates.ts）；空=classic
  modelUsed        String?   // v3.2 本课生成所用 LLM 模型 key（见 src/lib/ai/models.ts）
  qualityTier      String    @default("standard") // v3.4 standard=确定性 / premium=优先 bespoke 精修
  premiumRenderCount Int     @default(0) // 成功命中 bespoke 的章节数
  deterministicRenderCount Int @default(0) // 确定性渲染或回落的章节数
  designJson       String?   // v3.3 课级设计系统（艺术方向 + 配色/字体 token + 动效旋钮）JSON，供 HTML 课件生成注入（见 src/lib/ai/courseware-design.ts）
  sourceDemandId   String?   // 由某共创需求生成（闭环追溯）
  instructorName   String?
  reviewerName     String? // 健康/财务/防诈骗类必填
  disclaimer       String? // 免责声明
  contributorName  String? // 内容供给方/主讲（融合：弱化单一主讲依赖）
  revenueSharePct  Int? // 主讲分成比例，成本核算（有道痛点：主讲要 50-60%）
  updateCadence    String? // 每周更新 / 按题季 等
  totalDurationSec Int       @default(0)
  learnersCount    Int       @default(0)
  isFeatured       Boolean   @default(false)
  publishedAt      DateTime?
  lastUpdatedAt    DateTime  @default(now())
  createdAt        DateTime  @default(now())

  lessons    Lesson[]
  updateLogs CourseUpdateLog[]
  progress   LearningProgress[]
  notes      Note[]
  calendar   ContentCalendar[]
  reviews    CourseReview[]
  purchases  CoursePurchase[]

  @@index([sharedStatus, lastUpdatedAt]) // 课程集市列表：按分享状态过滤 + 时间排序
  @@index([authorUserId]) // 「我造/我导入的课」列表 + 用户删除时按作者反查（authorUserId 为软 FK，无级联，查询侧用索引兜住）
}

model Lesson {
  id            String    @id @default(cuid())
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title         String
  summary       String?
  sortOrder     Int       @default(0)
  contentType   String    @default("video") // video / article / mixed / live / ai_block / ai_html
  videoAssetId  String?   @unique // 一个受控资产只绑一个章节，避免共享 asset 造成鉴权语义歧义
  videoUrl      String? // 仅免费章节可用的公开媒体 URL；付费章节必须使用 videoAssetId
  articleMd     String?
  blocksJson    String? // ai_block 类型：结构化块课件 {version, blocks[]}（见 src/lib/blocks.ts）；也是 ai_html 课的内容层真值源 + 兜底
  htmlJson      String? // ai_html 类型：AI 生成的自包含沙箱 HTML 课件渲染契约 {renderMode, contractVersion, html, hasScript, checksum}（见 src/lib/ai/courseware-html.ts）
  htmlGenClaimedAt DateTime? // HTML 课件生成并发所有权占位（对齐 genClaimedAt 语义）
  renderEngine  String? // v3.4 llm / deterministic，供命中率与回落排障
  renderRejectReason String? // bespoke 被拒/预算/超时等原因（截断的人类可读摘要）
  renderSourceHash String? // blocks+design+mode+渲染版本校验和；相同输入直接复用
  renderDurationMs Int? // 本次 HTML 生成耗时
  genClaimedAt  DateTime? // 造课并发所有权占位：generateLessonCore 生成前原子 claim，防两条流水双写双扣（见 src/lib/course-gen.ts）
  // —— 视频课件生成（v3.1）：把块课件转成带旁白/字幕的视频。留接口，模型后补 ——
  // null=未发起 / pending=已排队 / generating=生成中 / ready=已就绪(videoAssetId 指向占位或真实资源) / failed=失败可重试
  videoGenStatus  String? // 视频课件生成态（复用 videoAssetId 承载产物引用）
  videoScriptJson String? // 由 blocks 组织出的视频脚本 {version, scenes:[{narration, caption, ...}]}（生成前落库，供真实模型消费）
  videoGenClaimedAt DateTime? // 视频生成并发所有权占位：generateLessonVideo 生成前原子 claim，防两条流水双写（对齐 genClaimedAt 语义）
  videoDurationSec Int? // v3.1 视频课件时长（秒）：与图文阅读语义的 durationSec 隔离，生成视频后写此字段，不污染块课共享的 durationSec
  durationSec   Int       @default(0)
  isFree        Boolean   @default(false)
  liveStartAt   DateTime? // 直播小班课开播时间（融合：有道口语小班课）
  liveSeatLimit Int? // 小班名额上限
  status        String    @default("published")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  progress  LearningProgress[]
  notes     Note[]
  subtitles Subtitle[]

  @@index([courseId, sortOrder])
}

// ---------- 字幕（C1：字幕划线捕捉）----------
model Subtitle {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lang     String @default("zh") // zh / en
  startSec Float
  endSec   Float
  text     String

  @@index([lessonId, startSec])
}

model CourseUpdateLog {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId    String?
  updateType  String // added / revised / fixed / removed
  title       String
  description String?
  ownerId     String?
  publishedAt DateTime @default(now())

  // 课程详情页 include updateLogs（WHERE courseId ORDER BY publishedAt）+ 全局更新流 orderBy publishedAt。
  // SQLite 不为外键自动建索引，热点路径此前全表扫 + 排序。（审计 2026-07-12 P2-5）
  @@index([courseId, publishedAt])
}

// ---------- §9.3 学习进度 ----------
model LearningProgress {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progressSec  Int       @default(0) // 视频/模拟播放的秒数进度（时间轴锚点）
  lastSlideIndex Int?    // 翻页课件「已读到第几页」(1-indexed)：与 progressSec 的秒数语义隔离，两个视图的续读锚点互不覆盖
  completedAt  DateTime?
  lastPlayedAt DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, lessonId])
}

// ---------- 课程评价（S5 评价系统闭环）----------
// 一人一课一评（@@unique([userId, courseId])）：再次提交为 upsert 覆盖，避免刷分。
// 评价资格在 API 层校验（须有该课的 LearningProgress，即「学过才可评」），
// 不落库到本表——资格是行为派生，不是评价本身的字段。
// rating 1-5 整数星级；comment 可空（允许只打分不写字）。
model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int // 1-5 整数星级（API 层夹紧校验）
  comment   String? // 文字评价，可空（只打分不写字）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId]) // 一人一课一评：重复提交走 upsert
  @@index([courseId, createdAt]) // 评价列表：按课过滤 + 时间排序
}

// ---------- 课程购买 / 所有权真值源（交易系统根因修复）----------
// 独立的「谁拥有哪门课」真值源，与 LearningProgress（免费节进度）解耦：
//   - 所有权判据：买家/免费拿走者持有该课一条 CoursePurchase 记录 = 拥有本课全部章节。
//   - 幂等真值源：@@unique([userId, courseId]) 一人一课一条——重复购买撞唯一约束即「已拥有」，
//     不再用「免费节 LearningProgress」判幂等（免费预览不再污染所有权 / 白拿付费课）。
//   - priceCredits：购买当时价格快照（付费=正整数售价，免费拿走=0），作对账/收益溯源锚点。
// 与 LearningProgress 的分工：LearningProgress 管「学到哪」（进度/续读），CoursePurchase 管「有没有」（所有权）。
model CoursePurchase {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  priceCredits Int      // 购买当时价格快照：付费=售价，免费拿走=0
  createdAt    DateTime @default(now())

  @@unique([userId, courseId]) // 一人一课一条：天然幂等 + 所有权真值源
  @@index([courseId])
}

// ---------- §9.4 笔记（2.0：捕捉 + 资产化）----------
model Note {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // courseId/lessonId 可空：v2.2 起支持「独立笔记」(source=manual) 与 AI 整理产物(source=ai_transform)，
  // 它们不绑定任何课程/章节；课程内记的笔记(source=lesson)继续填这两个字段。
  courseId     String?
  // onDelete: SetNull（审计 2026-07-12 P2-8）：此前为 Cascade——一旦将来加课程/章节硬删路径
  // （或有人用 Studio/脚本删课），会连带删掉所有学习者挂该课/节的笔记（用户数据丢失）。
  // 字段本就可空且支持独立笔记，删课时把笔记转为独立笔记（courseId/lessonId 置空）更安全。
  course       Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lessonId     String?
  lesson       Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  timestampSec Int?
  anchorRef    String? // 块课件锚点 "block:<id>" / "chapter:<n>"（视频课继续用 timestampSec）
  title        String?
  contentMd    String
  excerpt      String? // v2.2：列表预览摘要（写入时由 contentMd 生成，≤120 字，避免列表动态截断，借鉴 LeoJarvis）
  source       String    @default("lesson") // v2.2：lesson / manual / ai_transform / link_import(链接导入)
  sourceUrl    String? // v2.3：链接导入的原始网址（source=link_import 时）
  sourceText   String? // C1：字幕划线引用的原文
  kind         String    @default("text") // text / capture(截帧) / clip(字幕剪藏)
  captureUrl   String? // 截帧图 data-url 或对象存储 key
  starred      Boolean   @default(false) // 收藏/星标
  pinned       Boolean   @default(false) // v2.2：置顶（列表 pinned DESC 优先，借鉴 LeoJarvis）
  notebookId   String? // v2.2：归属笔记本（可空）
  notebook     Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  visibility   String    @default("private") // private / shared_later
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tags        NoteTagOnNote[]
  attachments NoteAttachment[]

  @@index([userId, createdAt])
  @@index([userId, lessonId])
  @@index([userId, pinned, updatedAt]) // v2.2：笔记馆「全部」列表默认排序（置顶优先 + 最近更新）
  @@index([notebookId])
  @@index([courseId])
}

// ---------- 笔记标签（C1：标签系统）----------
model NoteTag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("accent")
  createdAt DateTime @default(now())

  notes NoteTagOnNote[]

  @@unique([userId, name])
  @@index([userId])
}

model NoteTagOnNote {
  noteId String
  note   Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tagId  String
  tag    NoteTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

// ---------- §9.5 共创需求 ----------
model Demand {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade) // 收敛：与所有其他 user 关系一致走 Cascade（此前缺省 NoAction，删用户会因 demand 外键失败，形成「半 Cascade 半 Restrict」不一致）
  title            String
  description      String?
  category         String   @default("ai_skill")
  desiredDepth     String   @default("intro") // intro / advanced / mastery
  status           String   @default("pending_review")
  mergedToDemandId String?
  officialReply    String?
  riskLevel        String   @default("low")
  launchedCourseId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  votes      DemandVote[]
  statusLogs DemandStatusLog[]
  comments   Comment[]
  follows    DemandFollow[]
  stages     DemandStage[]

  @@index([category, status])
  @@index([createdAt])
  @@index([userId])
}

model DemandVote {
  id        String   @id @default(cuid())
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voteCount Int      @default(1)
  weekKey   String // e.g. 2026-W27
  createdAt DateTime @default(now())

  @@unique([demandId, userId, weekKey])
  @@index([weekKey, userId])
  @@index([demandId])
}

// ---------- 共创讨论（C2.1：需求讨论区，多态挂载）----------
model Comment {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  demandId   String?
  demand     Demand?   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  parentId   String? // 楼中楼
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  contentMd  String
  isOfficial Boolean   @default(false) // 官方回复置顶
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@index([demandId, createdAt])
  @@index([userId])
}

// ---------- 需求关注（C2.4：进度订阅）----------
model DemandFollow {
  id        String   @id @default(cuid())
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([demandId, userId])
  @@index([userId])
}

// ---------- 制作进度剧场（C2.2：Kickstarter 式阶段）----------
model DemandStage {
  id        String   @id @default(cuid())
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  stage     String // scripting / recording / editing / reviewing / published
  status    String   @default("pending") // pending / active / done
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([demandId])
}

model DemandStatusLog {
  id         String   @id @default(cuid())
  demandId   String
  demand     Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  operatorId String?
  reason     String?
  createdAt  DateTime @default(now())

  @@index([demandId]) // 需求详情页 include statusLogs（审计 2026-07-12 P2-7）
}

// ---------- §9.6 订阅与订单 ----------
model Plan {
  id              String  @id @default(cuid())
  name            String
  billingPeriod   String // month / quarter / year / month_recurring
  priceCents      Int
  firstPriceCents Int?
  currency        String  @default("CNY")
  channel         String  @default("any")
  scope           String  @default("all") // "all"=全站会员；否则为单赛道 key（分赛道自由组合订阅）
  highlight       Boolean @default(false)
  isActive        Boolean @default(true)

  orders        Order[]
  subscriptions Subscription[]
}

// ---------- 优惠券 / 兑换码（D1：运营必需）----------
model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  kind          String    @default("percent") // percent / fixed
  value         Int // percent: 0-100；fixed: 分
  maxRedeem     Int       @default(0) // 0=不限
  redeemedCount Int       @default(0)
  planScope     String    @default("any") // any 或指定 planId
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  orders      Order[]
  redemptions CouponRedemption[]
}

// 核销记录（流3-U4b）：每次订单成功抵扣一张券记一条。
// (couponId,orderId) 唯一 —— 同一订单绝不重复核销（webhook 重放/并发下的第二次自增被此约束挡下）。
model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  orderId   String
  createdAt DateTime @default(now())

  @@unique([couponId, orderId])
  // 每人限用一次（审计 2026-07-12 P2-1）：下单时以此约束原子预留、防同一用户反复用同券薅折扣。
  @@unique([couponId, userId])
  @@index([userId])
}

// ---------- 兑换码体系（v3.3）----------
// 与 Coupon（仅支付折扣）正交：兑换码可直接发放积分 / 会员天数，有独立用户兑换入口。
// 管理员批量生成（一批 batchId）→ 用户输入码兑换 → 原子核销（码状态翻转 + 积分/会员发放同事务）。
model RedemptionCode {
  id          String    @id @default(cuid())
  code        String    @unique // 兑换码明文（生成时分组格式，如 TIDE-XXXX-XXXX-XXXX）
  batchId     String    // 批次号：一次批量生成共用，便于按批作废/统计
  type        String    // credits（发积分）/ membership（发会员天数）
  value       Int       // credits: 积分数；membership: 会员天数
  planId      String?   // membership 类可选指定 plan（空则用默认全站会员发放逻辑）
  maxUses     Int       @default(1) // 可被兑换次数（1=一次性单人；>1=多人共用码）
  usedCount   Int       @default(0)
  status      String    @default("active") // active / disabled（作废）
  note        String?   // 备注（活动名等）
  expiresAt   DateTime?
  createdById String?   // 生成的管理员
  createdBy   User?     @relation("RedemptionCodeCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  records     RedemptionRecord[]

  @@index([batchId])
  @@index([status, expiresAt])
}

// 核销记录：谁在何时兑了哪张码得到什么。(codeId,userId) 唯一 —— 同一人对同一码只兑一次（防重放）。
model RedemptionRecord {
  id           String   @id @default(cuid())
  codeId       String
  code         RedemptionCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedType  String   // credits / membership（快照，便于审计）
  grantedValue Int      // 实发积分数 / 会员天数
  createdAt    DateTime @default(now())

  @@unique([codeId, userId])
  @@index([userId])
}

// ---------- 邀请返利（流3-U4b）----------
// 一人一码：InviteCode 记「谁的邀请码」；Referral 记「谁通过谁的码注册、双方是否已返利」。
model InviteCode {
  id        String   @id @default(cuid())
  inviterId String   @unique // 一人一码：一个用户至多一条邀请码
  code      String   @unique
  createdAt DateTime @default(now())

  inviter   User      @relation("InviteCodeOwner", fields: [inviterId], references: [id], onDelete: Cascade)
  referrals Referral[]
}

model Referral {
  id           String    @id @default(cuid())
  inviteCodeId String
  inviteCode   InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  inviterId    String
  inviteeId    String     @unique // 一个新用户只能被返利一次（防重复 bind）
  rewardedAt   DateTime?
  createdAt    DateTime   @default(now())

  inviter User @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User @relation("ReferralInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviterId])
}

model Order {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  planId          String
  plan            Plan      @relation(fields: [planId], references: [id])
  channel         String // web_wechat / web_alipay / stripe / apple_iap / google_play
  amountCents     Int
  currency        String    @default("CNY")
  status          String    @default("pending") // pending / paid / refunded / failed
  externalOrderId String?   @unique // 渠道订单号：唯一，webhook 据此精确定位订单，杜绝重复激活
  couponId        String?
  coupon          Coupon?   @relation(fields: [couponId], references: [id])
  discountCents   Int       @default(0)
  // 支付成功后记录本单激活/续期的订阅：退款时据此精确撤销「这一笔」而非该 plan 下全部订阅
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  createdAt       DateTime  @default(now())
  paidAt          DateTime?

  @@index([userId, status, createdAt])
}

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  planId                 String
  plan                   Plan     @relation(fields: [planId], references: [id])
  channel                String
  scope                  String   @default("all") // 从 plan.scope 快照，决定该订阅覆盖的赛道
  externalSubscriptionId String?
  status                 String // trial / active / grace_period / billing_retry / canceled_but_active / expired / refunded / revoked
  priceSnapshotCents     Int      @default(0) // D1：下次续费价格快照
  billingRetryCount      Int      @default(0) // 扣款重试次数
  currentPeriodStart     DateTime @default(now())
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  entitlements Entitlement[]
  orders       Order[] // 激活/续期本订阅的订单（退款时据此精确定位）

  @@index([userId, status, currentPeriodEnd])
}

model Entitlement {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  sourceSubscriptionId String?
  subscription         Subscription? @relation(fields: [sourceSubscriptionId], references: [id])
  status               String // active / expired / revoked
  accessLevel          String        @default("free") // free / premium / family_member
  validFrom            DateTime      @default(now())
  validUntil           DateTime?
  snapshotJson         String        @default("{}")
  updatedAt            DateTime      @updatedAt

  // 并发写权益快照的幂等键：同一订阅每人至多一行。
  // sourceSubscriptionId 可空（未绑定订阅的 free 快照），SQLite 允许多个 NULL 并存，
  // 不会误伤 free 行；upsert 只在非 null 分支走复合唯一键。
  @@unique([userId, sourceSubscriptionId])
}

model PaymentWebhookLog {
  id           String    @id @default(cuid())
  channel      String
  eventType    String
  externalId   String
  payloadJson  String
  processedAt  DateTime?
  status       String    @default("received") // received / processed / duplicate / error
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@unique([channel, externalId])
}

// ---------- §9.7 家庭组 (P2 预留) ----------
model FamilyGroup {
  id          String         @id @default(cuid())
  ownerUserId String
  planId      String?
  createdAt   DateTime       @default(now())
  expiredAt   DateTime?
  members     FamilyMember[]
}

model FamilyMember {
  id            String      @id @default(cuid())
  familyGroupId String
  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  userId        String?
  role          String      @default("member") // owner / member
  inviteStatus  String      @default("pending") // pending / joined
  joinedAt      DateTime?
}

// ---------- §9.8 埋点事件 ----------
model AnalyticsEvent {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  anonymousId    String?
  eventName      String
  propertiesJson String   @default("{}")
  platform       String   @default("web")
  createdAt      DateTime @default(now())

  // 全站最热写表：埋点查询按事件名 + 时间范围、按用户漏斗高频过滤，补两条覆盖索引。
  @@index([eventName, createdAt])
  @@index([userId, eventName, createdAt])
}

// ---------- §8.2.2 内容排期 ----------
model ContentCalendar {
  id                 String   @id @default(cuid())
  courseId           String
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId           String?
  demandId           String? // 融合：共创需求 → 选题排期（投票驱动 + 投流数据双输入）
  title              String
  plannedPublishDate DateTime
  owner              String?
  status             String   @default("planned") // planned / recording / editing / review / scheduled / published / delayed
  riskLevel          String   @default("low")
  delayReason        String?

  // 排期看板按课程/计划发布日筛选与排序（审计 2026-07-12 P2-7）
  @@index([courseId])
  @@index([plannedPublishDate])
}

// ---------- 预约试听 / 建联线索（融合有道 0转正 + 电联建联漏斗）----------
model Lead {
  id            String   @id @default(cuid())
  userId        String? // 登录用户可关联；未登录留资也可
  name          String?
  phone         String?
  courseId      String? // 意向课程/赛道
  track         String?
  source        String   @default("youdao_dict") // 渠道：youdao_dict(端内私域) / ad_external(端外投放) / private_domain(私域) / organic
  channelDetail String? // 具体投放位/活动
  status        String   @default("new") // new / contacting(电联中) / booked(已预约试听) / trialing(试听中) / converted(已转化) / lost(流失)
  assigneeId    String? // support 跟进人
  followUpNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 建联队列按状态/跟进人筛选、按时间排序，随投放增长（审计 2026-07-12 P2-7）
  @@index([status])
  @@index([assigneeId])
  @@index([createdAt])
}

// ---------- 后台审计日志 (§19 技术验收: audit log) ----------
model AuditLog {
  id         String   @id @default(cuid())
  operatorId String?
  action     String
  targetType String?
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  // 审计日志无限增长；/admin 按时间倒序翻页 + 按操作人过滤（审计 2026-07-12 P2-7）
  @@index([createdAt])
  @@index([operatorId])
}

// ---------- 学习激励（C3：连续学习 + 潮汐日历）----------
model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveDay String? // YYYY-MM-DD（Asia/Shanghai）
  updatedAt     DateTime @updatedAt
}

model StreakDay {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  day     String // YYYY-MM-DD（Asia/Shanghai）
  minutes Int    @default(0) // 当日学习分钟，决定潮汐日历水位
  notes   Int    @default(0)

  @@unique([userId, day])
  @@index([userId, day])
}

// ---------- 成就 / 徽章（C3）----------
model Achievement {
  id          String @id @default(cuid())
  key         String @unique // first_tide / week_streak / first_note / cocreator ...
  name        String
  description String
  icon        String @default("Medal")

  users UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ============================================================
// AI 自习室：生成引擎 / 导入资料 / 学习伴侣 / 复习卡
// ============================================================

// 引擎B：用户导入资料 → 结构化成课
model ImportedSource {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind              String   // paste_text / pdf / url / video(留接口)
  title             String?
  rawText           String?  // 提取出的纯文本（MVP：粘贴文本）
  sourceUrl         String?
  assetId           String?  // pdf/video 走 upload 路由的占位 assetId
  charCount         Int      @default(0)
  parseStatus       String   @default("pending") // pending / parsed / failed
  generatedCourseId String?  // 结构化成功后产出的 Course.id
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

// 引擎A/B 共用：AI 生成任务（状态记录 + 幂等 + 成本埋点，MVP 同步执行不做真队列）
model GenerationJob {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String   // course_outline / course_lesson / import_structure
  status           String   @default("queued") // queued / running / done / failed
  inputJson        String   @default("{}")
  resultRef        String?  // 产出的 courseId / lessonId
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  errorMessage     String?
  attempts         Int      @default(0)
  createdAt        DateTime @default(now())
  finishedAt       DateTime?

  @@index([userId, status])
}

// 中枢：AI 学习伴侣 对话线程
model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     String   // lesson:<id> / course:<id> / studio
  courseId  String?
  lessonId  String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id            String     @id @default(cuid())
  threadId      String
  thread        ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role          String     // user / assistant
  contentMd     String
  citationsJson String     @default("[]") // 引用的笔记/字幕/块锚点，前端可跳转
  createdAt     DateTime   @default(now())

  @@index([threadId, createdAt])
}

// 中枢：复习卡（P0 落库，P1 做 SM-2 调度）
model ReviewCard {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId       String?  // 来源笔记（可空：AI 生成卡）
  courseId     String?
  front        String
  back         String
  dueAt        DateTime // 下次复习
  ease         Float    @default(2.5)
  intervalDays Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, dueAt])
}

// ============================================================
// v2.1：笔记知识库 / 自习室社区 / 专注会话
// ============================================================

// §5.3 知识库 Notebook：跨课程聚合笔记+资料+复习卡的主题空间
model Notebook {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  icon        String?  // emoji 或图标 key
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries NotebookEntry[]
  notes   Note[] // v2.2：归入本笔记本的笔记（Note.notebookId）

  @@index([userId, updatedAt])
}

// 知识库条目（多态：笔记/导入资料/复习卡/AI生成的洞察）
model NotebookEntry {
  id         String   @id @default(cuid())
  notebookId String
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  kind       String   // note / source / card / insight
  refId      String?  // 关联的 Note/ImportedSource/ReviewCard id
  title      String?
  contentMd  String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([notebookId, sortOrder])
}

// §7 自习室社区帖子（严格管控）—— 微博/X 式微内容流
model Post {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // insight(学习心得) / checkin(打卡) / question(求助)
  content      String
  refJson      String   @default("{}") // 引用的笔记/成就/streak 卡片数据
  images       String   @default("[]") // JSON 字符串数组：1-4 张图片 url（SQLite 无原生数组）
  topicTags    String   @default("[]") // JSON 字符串数组：话题标签（不含 # 前缀）
  status       String   @default("pending") // pending / approved / rejected
  rejectReason String?
  likeCount    Int      @default(0)
  commentCount Int      @default(0) // 评论数（发评论时 +1，与 PostComment 同事务维护）
  repostCount  Int      @default(0) // 转发数（被转发时 +1）
  repostOfId   String?  // 转发指向的原帖 id（null=原创帖）
  repostOf     Post?    @relation("PostRepost", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts      Post[]   @relation("PostRepost")
  createdAt    DateTime @default(now())

  likes    PostLike[]
  comments PostComment[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([repostOfId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// §9 专注会话（入席仪式）
model FocusSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId   String?
  courseId   String?
  goal       String?   // 本次专注目标
  startAt    DateTime  @default(now())
  endAt      DateTime?
  minutes    Int       @default(0)
  summary    String?   // 离席 AI 小结
  createdAt  DateTime  @default(now())

  @@index([userId, startAt])
}

// ==================== v2.3 积分经济系统 ====================

/** 积分账户：每用户一个，balance 由 CreditLedger 流水派生（写时同步更新）。 */
model CreditAccount {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Int      @default(0) // 当前余额（积分）
  totalEarned     Int      @default(0) // 累计入账（统计用）
  totalSpent      Int      @default(0) // 累计消耗（统计用）
  monthlyGrantKey String?  // 上次月度赠送的月份 key "2026-07"，防重复发放
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/** 积分流水（不可变，审计与对账的根）。 */
model CreditLedger {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int      // 正=入账 负=消耗
  type         String   // monthly_grant / recharge / share_reward / llm_spend / admin_adjust；signup_bonus 仅为历史兼容
  refId        String?  // 关联 Order/LlmUsage/CourseAccessRequest id
  reason       String?  // 展示文案 / admin 调账备注
  balanceAfter Int      // 记账后余额快照（对账用）
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  // 复合索引：既服务 admin/credits 按 type 统计（type 前缀），又服务 IAP 退款按 (type, refId) 精确查
  // recharge 行（此前只有 [type]，退款 clawback 需扫全部 recharge 行）。（审计 2026-07-12 P2-7）
  @@index([type, refId])
}

/** LLM Token 用量原始记录（积分折算依据）。 */
model LlmUsage {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scene            String   // generate_course / generate_lesson / companion / note_transform / note_summary / import_source / generate_exam / search_expand
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  creditCost       Int      @default(0) // 本次折算并扣除的积分
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([scene])
}

/** 角色权限矩阵（从代码常量 ROLE_PERMISSIONS 升级为 DB，admin 可调，代码保留默认兜底）。 */
model RolePermission {
  role       String
  permission String
  createdAt  DateTime @default(now())

  @@id([role, permission])
  @@index([role])
}

// (v2.3 AuditLog 复用已有定义于上方，operatorId 即操作者)

// ==================== v2.3 §1 课程集市（课程共享 + 申请学习）====================

/** 课程访问申请：他人申请学习某分享课程；作者批准后申请者获学习权。 */
model CourseAccessRequest {
  id          String   @id @default(cuid())
  courseId    String
  requesterId String   // 申请人 userId
  ownerId     String   // 课程作者 userId（冗余便于查"我的分享"）
  status      String   @default("pending") // pending / approved / rejected
  message     String?  // 申请留言
  decidedAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([courseId, requesterId]) // 同一人对同一课只能申请一次
  @@index([ownerId, status])
  @@index([requesterId, status])
}

// ==================== v2.3 §1 自习室广场升级（评论/转发）====================

/** 帖子评论（一级盖楼）。 */
model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  status    String   @default("approved") // approved / pending / rejected
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// ==================== v2.3 §3 笔记采集（附件）====================

/** 笔记附件：图片/PDF/文档。path 是私有存储 key，下载必须经过笔记本人鉴权。 */
model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  fileName  String
  mimeType  String
  size      Int
  path      String   // 私有磁盘文件名或对象存储 key；历史行可能是 /uploads/xxx
  summary   String?  // 文本类附件的 AI 摘要
  createdAt DateTime @default(now())

  @@index([noteId])
}

// ==================== v2.3 §8 模拟考试 ====================

model Exam {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  scopeType  String   // course / notebook / all
  scopeId    String?  // courseId / notebookId（all 时空）
  difficulty String   @default("basic") // basic / advanced
  status     String   @default("ready") // generating / ready / failed
  createdAt  DateTime @default(now())

  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([userId, createdAt])
}

model ExamQuestion {
  id          String  @id @default(cuid())
  examId      String
  exam        Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  type        String  // single(单选) / judge(判断) / short(简答)
  stem        String
  optionsJson String? // 单选：["A","B",...]（judge/short 为空）
  answer      String  // 单选=选项索引；判断=true/false；简答=参考答案
  explanation String?
  sourceRef   String? // "第 N 讲" / 笔记标题，溯源
  sortOrder   Int     @default(0)

  @@index([examId, sortOrder])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answersJson String   // 用户作答 {questionId: answer}
  score       Int      @default(0)
  total       Int      @default(0)
  detailJson  String?  // 判卷详情（每题对错+简答评语）
  finishedAt  DateTime @default(now())

  @@index([userId, finishedAt])
}

// 错题本（流3-U3）：每次判卷把判错的题落一条，供「错题回顾 / 复习闭环」查询。
// 幂等：以 attemptId+questionId 唯一——同一 attempt 重复提交先删旧错题再插，绝不堆积。
// 溯源字段（stem/correctAnswer/userAnswer/sourceRef）在落库时快照，即使原 Exam 被删也可回顾。
model ExamMistake {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId        String   // 来源试卷（软引用：Exam 删除不级联，靠快照字段保留题面）
  attemptId     String   // 来源作答（幂等键的一半）
  questionId    String   // 来源题目（幂等键的一半）
  stem          String   // 题干快照
  correctAnswer String   // 正确答案快照（single=选项索引 / judge=true|false / short=参考答案）
  userAnswer    String   // 我的作答快照
  sourceRef     String?  // "第 N 讲" / 笔记标题，溯源
  courseId      String?  // 归属课程（若试卷 scopeType=course，则为 scopeId，供按课过滤）
  createdAt     DateTime @default(now())

  @@unique([attemptId, questionId]) // 幂等：同 attempt 同题只留一条
  @@index([userId, createdAt]) // 错题本列表：按人过滤 + 时间排序
  @@index([userId, courseId]) // 按课程分组/过滤
}

// ==================== v2.3 §9 站内通知 ====================

model Notification {
  id        String    @id @default(cuid())
  userId    String    // 接收者
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // access_request / access_approved / post_comment / post_like / course_update / credit_grant / system
  title     String
  body      String?
  refType   String?   // course / post / request / exam
  refId     String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

// ==================== iOS APNs 推送设备注册 ====================

model Device {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // APNs device token（去重键）
  platform  String   @default("ios") // ios（后续可扩展 android）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

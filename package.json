{
  "name": "tide-learning",
  "version": "1.0.0",
  "private": true,
  "description": "潮汐学习 — 全龄订阅制学习平台 v1.0（网易有道出品）",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "preview": "npm run build && DATABASE_URL=\"file:./dev.db\" PORT=3100 next start -p 3100",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "setup": "prisma generate && prisma db push && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.1.0",
    "@types/jsdom": "^28.0.3",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "jsdom": "^29.1.1",
    "next": "15.1.3",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
